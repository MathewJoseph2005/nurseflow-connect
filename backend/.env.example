PORT=4000

# Primary MongoDB Atlas connection string (SRV)
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority&appName=nurseflow-connect

# Optional fallback when SRV DNS lookups are blocked on your network.
# Use Atlas "Standard connection string" (non-SRV) format:
# mongodb://<db_username>:<db_password>@<host1>:27017,<host2>:27017,<host3>:27017/<db_name>?replicaSet=<replica-set>&ssl=true&authSource=admin
MONGODB_URI_DIRECT=

# Optional: set to true to try MONGODB_URI_DIRECT before MONGODB_URI
MONGODB_PREFER_DIRECT=true

# App security
JWT_SECRET=<generate_a_long_random_secret>

# Allowed frontend origins (comma-separated if multiple)
CORS_ORIGIN=http://localhost:8080
